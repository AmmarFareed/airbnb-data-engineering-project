# -----------------------
# Python
# -----------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
ENV/
.venv/

# Distribution / packaging
build/
dist/
*.egg-info/

# -----------------------
# Jupyter Notebooks
# -----------------------
.ipynb_checkpoints/

# -----------------------
# OS Files
# -----------------------
.DS_Store
Thumbs.db

# -----------------------
# Logs
# -----------------------
*.log

# -----------------------
# IDE
# -----------------------
.vscode/
.idea/

# -----------------------
# Data (IMPORTANT)
# -----------------------
# Ignore raw and processed data
data/raw/*
data/processed/*
data/output/*

# BUT keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/output/.gitkeep

# -----------------------
# Large files
# -----------------------
*.csv
*.gz
*.parquet

# (Optional: allow small sample files)
!data/sample.csv

# -----------------------
# Reports (optional)
# -----------------------
# Keep final report, ignore drafts
reports/*.docx