# -----------------------
# Data (IMPORTANT)
# -----------------------

# Ignore raw and processed data
data/raw/*
data/processed/*
data/output/*

# BUT keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/output/.gitkeep

# Optional: allow sample data
!data/sample.csv

